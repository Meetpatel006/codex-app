{
  "name": "codex-app",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "check-types": "turbo run check-types",
    "run:stack": "pwsh -NoProfile -Command \"Set-Item -Path Env:REMODEX_RELAY -Value 'https://jalisa-unreputed-cleta.ngrok-free.dev/relay'; Start-Process ngrok -ArgumentList 'http','9000'; node ./scripts/run-relay-bridge.js\"",
    "serve:relay-test": "node ./scripts/serve-relay-test.js",
    "test:bridge:windows": "node --test ./packages/bridge/test/*.test.js --test-name-pattern='^(?!.*macOS).*$'"
  },
  "devDependencies": {
    "prettier": "^3.7.4",
    "turbo": "^2.8.20",
    "typescript": "5.9.2"
  },
  "engines": {
    "node": ">=18"
  },
  "packageManager": "bun@1.3.4",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "dependencies": {
    "@openai/apps-sdk-ui": "^0.2.1"
  }
}
